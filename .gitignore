# terraform/.gitignore
# Terraform state - NEVER commit
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfplan
tfplan
# State/plan dumps exported by hand don't match *.tfstate* - block them explicitly
state.json
plan_output.txt

# Bootstrap output
.bootstrap-output.txt

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Graphify
graphify-out/
.graphify/

# Function App deployment build artifacts
node_modules/
modules/functions/function_app.zip
